<!DOCTYPE html>
<html>
<head>
    <title>Room Bookings</title>

    <style>
        body{
            font-family: Arial, sans-serif;
            background:#eef2f7;
            margin:0;
            padding:20px;
        }

        h1{
            text-align:center;
            color:#1e6be3;
            font-size:50px;
            margin-bottom:20px;
        }

        table{
            width:100%;
            border-collapse:collapse;
            background:white;
        }

        th{
            background:#2475ea;
            color:white;
            padding:12px;
            text-align:left;
        }

        td{
            padding:12px;
            border-bottom:1px solid #ddd;
        }

        tr:nth-child(even){
            background:#f5f5f5;
        }

        .btn{
            text-decoration:none;
            color:white;
            padding:6px 10px;
            border-radius:4px;
            font-size:13px;
        }

        .update{
            background:#2475ea;
        }

        .delete{
            background:#f39c34;
        }

        .center{
            text-align:center;
            margin-top:30px;
        }

        .book-btn{
            background:#2475ea;
            color:white;
            padding:12px 20px;
            text-decoration:none;
            border-radius:5px;
        }
    </style>

</head>
<body>
    <h1>Room Bookings</h1>
    <table>
        <tr>
            <th>Customer Name</th>
            <th>Room Number</th>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Total Amount</th>
            <th>Actions</th>
        </tr>
        <% bookings.forEach(booking => { %>
            <tr>
                <td><%= booking.customerName %></td>

                <td><%= booking.roomNumber %></td>
                <td>
                    <%= new Date(booking.startTime).toLocaleString() %>
                </td>
                <td>
                    <%= new Date(booking.endTime).toLocaleString() %>
                </td>
                <td>
                    <%= booking.totalAmount.toLocaleString('vi-VN') %> VND
                </td>
                <td>
                    <a
                        class="btn update"
                        href="/bookings/update/<%= booking._id %>">
                        Update
                    </a>
                    <a
                        class="btn delete"
                        href="/bookings/delete/<%= booking._id %>"
                        onclick="return confirm('Delete this booking?')">
                        Delete
                    </a>
                </td>
            </tr>
        <% }) %>
    </table>
    <div class="center">
        <a
            href="/bookings/add"
            class="book-btn">
            Book a Room
        </a>
    </div>
</body>
</html>